<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <!-- ═══════════════════════════════════════════════════════════════════
         ASR29 — Ataque con credencial comprometida
         Simula 100 requests/min desde RU (anomalía GEO + VOLUME)
         Verifica que la credencial es revocada en < 10 minutos.
         USO: jmeter -n -t attack_compromised.jmx -JHOST=<ip> -JPORT=80 -JCRED_ID=cred-xxx
         ═══════════════════════════════════════════════════════════════════ -->
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="ASR29 - Ataque Credencial Comprometida" enabled="true">
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments">
        <collectionProp name="Arguments.arguments">
          <elementProp name="HOST" elementType="Argument">
            <stringProp name="Argument.name">HOST</stringProp>
            <stringProp name="Argument.value">${__P(HOST,localhost)}</stringProp>
          </elementProp>
          <elementProp name="PORT" elementType="Argument">
            <stringProp name="Argument.name">PORT</stringProp>
            <stringProp name="Argument.value">${__P(PORT,80)}</stringProp>
          </elementProp>
          <elementProp name="CRED_ID" elementType="Argument">
            <stringProp name="Argument.name">CRED_ID</stringProp>
            <stringProp name="Argument.value">${__P(CRED_ID,cred-attack-001)}</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
      <hashTree>
        <!-- Thread Group: 20 usuarios, alta frecuencia, desde RU -->
        <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Atacantes desde RU" enabled="true">
          <intProp name="ThreadGroup.num_threads">20</intProp>
          <intProp name="ThreadGroup.ramp_time">10</intProp>
          <boolProp name="ThreadGroup.scheduler">true</boolProp>
          <stringProp name="ThreadGroup.duration">300</stringProp>
          <elementProp name="ThreadGroup.main_controller" elementType="LoopController">
            <boolProp name="LoopController.continue_forever">true</boolProp>
          </elementProp>
          <hashTree>
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /credentials/use/ [ATAQUE]" enabled="true">
              <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
              <stringProp name="HTTPSampler.port">${PORT}</stringProp>
              <stringProp name="HTTPSampler.path">/credentials/use/</stringProp>
              <stringProp name="HTTPSampler.method">POST</stringProp>
              <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                <collectionProp name="Arguments.arguments">
                  <elementProp name="" elementType="HTTPArgument">
                    <stringProp name="Argument.value">{"credential_id":"${CRED_ID}","geo_country":"RU","endpoint":"/admin/export_all"}</stringProp>
                    <stringProp name="Argument.metadata">=</stringProp>
                  </elementProp>
                </collectionProp>
              </elementProp>
              <elementProp name="HTTPSampler.header_manager" elementType="HeaderManager">
                <collectionProp name="HeaderManager.headers">
                  <elementProp name="" elementType="Header">
                    <stringProp name="Header.name">Content-Type</stringProp>
                    <stringProp name="Header.value">application/json</stringProp>
                  </elementProp>
                </collectionProp>
              </elementProp>
            </HTTPSamplerProxy>
            <hashTree/>

            <!-- Sin pausa para maximizar la tasa de requests -->
          </hashTree>
        </ThreadGroup>

        <!-- Thread Group: verificar revocación cada 30s -->
        <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Monitor Revocación" enabled="true">
          <intProp name="ThreadGroup.num_threads">1</intProp>
          <intProp name="ThreadGroup.ramp_time">0</intProp>
          <boolProp name="ThreadGroup.scheduler">true</boolProp>
          <stringProp name="ThreadGroup.duration">600</stringProp>
          <elementProp name="ThreadGroup.main_controller" elementType="LoopController">
            <boolProp name="LoopController.continue_forever">true</boolProp>
          </elementProp>
          <hashTree>
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /credentials/audit/" enabled="true">
              <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
              <stringProp name="HTTPSampler.port">${PORT}</stringProp>
              <stringProp name="HTTPSampler.path">/credentials/audit/</stringProp>
              <stringProp name="HTTPSampler.method">GET</stringProp>
            </HTTPSamplerProxy>
            <hashTree/>

            <ConstantTimer guiclass="ConstantTimerGui" testclass="ConstantTimer" testname="Esperar 30s" enabled="true">
              <stringProp name="ConstantTimer.delay">30000</stringProp>
            </ConstantTimer>
            <hashTree/>
          </hashTree>
        </ThreadGroup>

        <ResultCollector guiclass="SummaryReport" testclass="ResultCollector" testname="Summary Report" enabled="true">
          <objProp>
            <name>saveConfig</name>
            <value class="SampleSaveConfiguration">
              <time>true</time>
              <latency>true</latency>
              <timestamp>true</timestamp>
              <success>true</success>
              <label>true</label>
              <code>true</code>
            </value>
          </objProp>
          <stringProp name="filename">results_attack.csv</stringProp>
        </ResultCollector>
        <hashTree/>
      </hashTree>
    </TestPlan>
  </hashTree>
</jmeterTestPlan>
