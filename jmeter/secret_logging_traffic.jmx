<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <!-- ═══════════════════════════════════════════════════════════════════
         ASR30 — Tráfico que intenta filtrar datos sensibles en logs
         Llama a los endpoints /test/leak/* que loguean secretos falsos.
         Verifica que los logs resultantes contienen solo ****.
         USO: jmeter -n -t secret_logging_traffic.jmx -JHOST=<ip> -JPORT=80
         ═══════════════════════════════════════════════════════════════════ -->
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="ASR30 - Tráfico con Secretos en Logs" enabled="true">
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments">
        <collectionProp name="Arguments.arguments">
          <elementProp name="HOST" elementType="Argument">
            <stringProp name="Argument.name">HOST</stringProp>
            <stringProp name="Argument.value">${__P(HOST,localhost)}</stringProp>
          </elementProp>
          <elementProp name="PORT" elementType="Argument">
            <stringProp name="Argument.name">PORT</stringProp>
            <stringProp name="Argument.value">${__P(PORT,80)}</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
      <hashTree>
        <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Tráfico con secretos" enabled="true">
          <intProp name="ThreadGroup.num_threads">10</intProp>
          <intProp name="ThreadGroup.ramp_time">10</intProp>
          <boolProp name="ThreadGroup.scheduler">true</boolProp>
          <stringProp name="ThreadGroup.duration">120</stringProp>
          <elementProp name="ThreadGroup.main_controller" elementType="LoopController">
            <boolProp name="LoopController.continue_forever">true</boolProp>
          </elementProp>
          <hashTree>
            <HTTPSamplerProxy testname="GET /test/leak/aws-key/" enabled="true">
              <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
              <stringProp name="HTTPSampler.port">${PORT}</stringProp>
              <stringProp name="HTTPSampler.path">/test/leak/aws-key/</stringProp>
              <stringProp name="HTTPSampler.method">GET</stringProp>
            </HTTPSamplerProxy>
            <hashTree/>

            <HTTPSamplerProxy testname="GET /test/leak/jwt/" enabled="true">
              <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
              <stringProp name="HTTPSampler.port">${PORT}</stringProp>
              <stringProp name="HTTPSampler.path">/test/leak/jwt/</stringProp>
              <stringProp name="HTTPSampler.method">GET</stringProp>
            </HTTPSamplerProxy>
            <hashTree/>

            <HTTPSamplerProxy testname="GET /test/leak/account/" enabled="true">
              <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
              <stringProp name="HTTPSampler.port">${PORT}</stringProp>
              <stringProp name="HTTPSampler.path">/test/leak/account/</stringProp>
              <stringProp name="HTTPSampler.method">GET</stringProp>
            </HTTPSamplerProxy>
            <hashTree/>

            <HTTPSamplerProxy testname="GET /test/leak/db-uri/" enabled="true">
              <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
              <stringProp name="HTTPSampler.port">${PORT}</stringProp>
              <stringProp name="HTTPSampler.path">/test/leak/db-uri/</stringProp>
              <stringProp name="HTTPSampler.method">GET</stringProp>
            </HTTPSamplerProxy>
            <hashTree/>

            <ConstantTimer guiclass="ConstantTimerGui" testclass="ConstantTimer" testname="Pausa 3s" enabled="true">
              <stringProp name="ConstantTimer.delay">3000</stringProp>
            </ConstantTimer>
            <hashTree/>
          </hashTree>
        </ThreadGroup>

        <ResultCollector guiclass="SummaryReport" testclass="ResultCollector" testname="Summary Report" enabled="true">
          <objProp>
            <name>saveConfig</name>
            <value class="SampleSaveConfiguration">
              <time>true</time>
              <latency>true</latency>
              <timestamp>true</timestamp>
              <success>true</success>
              <label>true</label>
              <code>true</code>
            </value>
          </objProp>
          <stringProp name="filename">results_secret_logging.csv</stringProp>
        </ResultCollector>
        <hashTree/>
      </hashTree>
    </TestPlan>
  </hashTree>
</jmeterTestPlan>
