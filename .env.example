# .env.example — Sprint 3 BITE.co
# Copiar a .env y rellenar los valores reales

# Django
DJANGO_SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bite_db
DB_USER=postgres
DB_PASSWORD=password

# MongoDB (mongos del cluster sharded)
MONGO_URI=mongodb://localhost:27017/bite_db

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=bite
RABBITMQ_PASSWORD=bitepass

# Vault de credenciales (ASR29)
# Generar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_KEY=

# Auth0 (reutilizado del Lab 8)
AUTH0_DOMAIN=your-domain.us.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_MGMT_TOKEN=

# Entorno (dev | test | prod) — usado para logs
AMBIENTE=dev
